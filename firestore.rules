rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidLead(data) {
      return data.keys().hasAll(['fullName', 'phone', 'email', 'address', 'services', 'createdAt'])
        && data.keys().size() == 6
        && data.fullName is string && data.fullName.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.email is string && data.email.size() <= 200
        && data.address is string && data.address.size() <= 500
        && data.services is list && data.services.size() <= 10
        && data.createdAt == request.time;
    }

    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(request.resource.data);
      allow read, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /sessions/{sessionId}/messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidId(sessionId) && isValidId(messageId)
        && request.resource.data.role in ['user', 'model']
        && request.resource.data.text is string
        && request.resource.data.createdAt == request.time;
    }
  }
}
